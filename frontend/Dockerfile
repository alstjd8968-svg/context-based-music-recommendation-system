# Base image (예: Node.js를 사용하는 React, Vue, Next.js 등)
FROM node:18-alpine

# Set working directory
WORKDIR /app

# Install dependencies (의존성 패키지 설치)
# COPY package.json package-lock.json ./
# RUN npm install

# Copy source code (소스 코드 전체 복사)
# COPY . .

# Build application (예: npm run build)
# RUN npm run build

# Expose port 80
EXPOSE 80

# Start application (예: npm start 또는 serve)
# CMD ["npm", "start"]
